# Copy this file to .env and fill in real values before running docker compose.
# Never commit the real .env file. All secrets below must be changed for any
# non local environment.

# ── Postgres (backing store for Keycloak) ──
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=change_me_postgres

# ── MongoDB (application data store) ──
MONGO_INITDB_ROOT_USERNAME=rudra
MONGO_INITDB_ROOT_PASSWORD=change_me_mongo

# ── Redis ──
REDIS_PASSWORD=change_me_redis

# ── Keycloak bootstrap admin ──
# Used only for the first boot. Create a real admin user and rotate this
# credential immediately after Keycloak is reachable.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_admin

# ── Backend ──
# SECRET_KEY signs JWTs issued by the backend. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change_me_generate_a_long_random_value

# Comma separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:3000
